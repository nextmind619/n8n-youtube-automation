# Copy to n8n Environment Variables (Settings > Variables) or .env for self-hosted n8n

# ── General ──────────────────────────────────────────────────────────────────
N8N_TIMEZONE=America/New_York
VIDEOS_PER_DAY=20
BATCH_DELAY_MINUTES=72
CHANNEL_NICHE=AI Workflow & Automation for Business - Make.com n8n Zapier no-code tutorials

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3

# ── ElevenLabs ───────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2

# ── Creatomate ───────────────────────────────────────────────────────────────
CREATOMATE_API_KEY=...
CREATOMATE_SHORT_TEMPLATE_ID=...
CREATOMATE_LONG_TEMPLATE_ID=...

# ── AI Video (Runway Gen-3 – optional, falls back to DALL-E images) ─────────
RUNWAY_API_KEY=...
RUNWAY_ENABLED=false

# ── Google Sheets ────────────────────────────────────────────────────────────
GOOGLE_SHEETS_DOCUMENT_ID=your-spreadsheet-id
GOOGLE_SHEETS_CONTENT_TAB=Content
GOOGLE_SHEETS_QUEUE_TAB=Queue
GOOGLE_SHEETS_ERRORS_TAB=Errors
GOOGLE_SHEETS_LOGS_TAB=Logs

# ── YouTube ──────────────────────────────────────────────────────────────────
YOUTUBE_CHANNEL_ID=UC...
YOUTUBE_DEFAULT_CATEGORY=28
YOUTUBE_DEFAULT_PRIVACY=public
YOUTUBE_TAGS=automation,n8n,make.com,zapier,no-code,ai tools,workflow,small business

# ── Workflow IDs (set after importing sub-workflows) ─────────────────────────
WORKFLOW_VIDEO_PRODUCTION_ID=
WORKFLOW_ERROR_HANDLER_ID=
