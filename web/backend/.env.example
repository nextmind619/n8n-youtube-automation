PORT=3001

# n8n
N8N_BASE_URL=https://darkvault.app.n8n.cloud
N8N_API_KEY=your-n8n-api-key

# Google Sheets (same spreadsheet as n8n workflows)
GOOGLE_SHEETS_DOCUMENT_ID=1iroszMZekztryhZ9djZ2IGcv6QRRm_o-EAMR6j1UPh0
GOOGLE_SHEETS_QUEUE_TAB=Queue
GOOGLE_SHEETS_CONTENT_TAB=Content
GOOGLE_SHEETS_ERRORS_TAB=Errors
GOOGLE_SHEETS_LOGS_TAB=Logs

# Service account JSON path OR inline JSON string
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=../../config/google-service-account.json

# Workflow IDs (for dashboard trigger buttons)
WORKFLOW_TOPIC_DISCOVERY_ID=
WORKFLOW_VIDEO_PRODUCTION_ID=

# Webhook paths (required on n8n Community Edition — /run API not available)
N8N_WEBHOOK_PATH=autopilot-trigger
# Or separate paths per button:
# N8N_WEBHOOK_DISCOVERY_PATH=autopilot-discovery
# N8N_WEBHOOK_PRODUCTION_PATH=autopilot-production
